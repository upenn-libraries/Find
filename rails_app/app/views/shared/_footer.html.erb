<%# This file is empty in Blacklight v9.0. This file overrides that to render our footer content. %>
<pennlibs-feedback></pennlibs-feedback>
<pennlibs-footer show-built-with>
  <section>
    <h2><%= t('footer.about.heading') %></h2>
    <%= link_to t('footer.about.home'), root_path %>
    <%= link_to t('footer.about.release_notes'), t('urls.release_notes') %>
  </section>
  <section>
    <h2><%= t('footer.account.heading') %></h2>
    <%= link_to t('footer.account.shelf'), shelf_path %>
    <%= link_to t('footer.account.request'), ill_new_request_path unless current_user&.courtesy_borrower? %>
    <%= link_to t('footer.account.bookmarks'), bookmarks_path %>
    <%= link_to t('footer.account.fines'), fines_and_fees_path %>
    <%= link_to t('footer.account.settings'), settings_path %>
  </section>
  <section>
    <h2><%= t('footer.guides.heading') %></h2>
    <%= link_to t('guides.use_catalog'), t('urls.guides.use_catalog') %>
    <%= link_to t('guides.articles+'), t('urls.guides.articles') %>
    <%= link_to t('guides.library_account'), t('urls.guides.account') %>
  </section>
</pennlibs-footer>

<pennlibs-chat></pennlibs-chat>
