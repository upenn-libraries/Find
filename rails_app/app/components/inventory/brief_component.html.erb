<turbo-frame id="inventory_<%= document.id %>" target="_top">
  <ol class="fi-options">
    <% entries.each do |entry| %>
      <%= render(Inventory::Brief::EntryComponent.new(entry: entry)) %>
    <% end %>
    <%= render(Inventory::Brief::RemainderComponent.new(document)) %>
  </ol>
</turbo-frame>